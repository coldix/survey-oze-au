# survey.oze.au — cache + source protection | v1.0.0

# HTML always fresh
<FilesMatch "\.(html?)$">
  Header set Cache-Control "no-store, must-revalidate"
</FilesMatch>

# Assets immutable (bump ?v= in HTML when needed)
<FilesMatch "\.(css|js|webp|png|jpg|svg|woff2?)$">
  Header set Cache-Control "public, max-age=31536000, immutable"
</FilesMatch>

# Block dev/source from web
<FilesMatch "(?i)\.(sh|md|gitignore|yml|yaml)$">
  Require all denied
</FilesMatch>